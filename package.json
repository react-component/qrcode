{
  "name": "@rc-component/qrcode",
  "version": "2.0.0",
  "description": "React QR Code component",
  "engines": {
    "node": ">=8.x"
  },
  "keywords": [
    "react",
    "react-component",
    "react-qrcode",
    "qrcode"
  ],
  "homepage": "https://react-component.github.io/qrcode",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-component/qrcode.git"
  },
  "bugs": {
    "url": "https://github.com/react-component/qrcode/issues"
  },
  "files": [
    "es",
    "lib",
    "assets/**/*.css",
    "assets/**/*.less"
  ],
  "license": "MIT",
  "main": "./lib/index",
  "module": "./es/index",
  "scripts": {
    "start": "dumi dev",
    "build": "npm run docs:build",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "gh-pages": "cross-env GH_PAGES=1 npm run docs:build && npm run docs:deploy",
    "compile": "father build && lessc assets/index.less assets/index.css",
    "prepublishOnly": "npm run compile && rc-np",
    "lint": "eslint src/ docs/examples/ --ext .tsx,.ts,.jsx,.js",
    "prettier": "prettier --write --ignore-unknown .",
    "test": "rc-test",
    "coverage": "rc-test --coverage",
    "tsc": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0"
  },
  "devDependencies": {
    "@ant-design/tools": "^19.2.0",
    "@eslint/js": "^10.0.1",
    "@eslint/compat": "^2.1.0",
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dumi": "^2.4.38",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "father": "^4.6.24",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest-canvas-mock": "^2.5.2",
    "less": "^4.6.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rc-test": "^7.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-jest": "^29.4.11",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "types": "./es/index.d.ts"
}
