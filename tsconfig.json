{
  "compilerOptions": {
    "target": "esnext",
    "moduleResolution": "node",
    "baseUrl": "./",
    "jsx": "react",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["src/*"],
      "@@/*": [".dumi/tmp/*"],
      "@rc-component/qrcode": ["src/index.tsx"]
    }
  },
  "include": [".dumirc.ts", "src", "docs", "tests"],
  "exclude": ["node_modules", "lib", "es", "dist", "docs-dist", ".dumi"]
}
